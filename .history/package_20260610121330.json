{
    "name": "gatsby-starter-modern-doc",
    "description": "Provides skeleton/boilerplate for building Modern Doc client websites using GatsbyJs.",
    "version": "1.0.0",
    "private": true,
    "author": "Modern Doc Media <sales@moderndocmedia.com>",
    "license": "UNLICENSED",
    "scripts": {
        "start": "gatsby develop --host 0.0.0.0",
        "build": "gatsby build",
        "serve": "gatsby serve",
        "preview": "gatsby clean && gatsby build && gatsby serve",
        "prepare": "husky install",
        "install": "npm install --legacy-peer-deps",
        "deploy": "./scripts/deploy.sh"
    },
    "browserslist": [
        ">.75%",
        "not dead",
        "not ie <= 11",
        "not op_mini all"
    ],
    "lint-staged": {
        "./src/**/*.{js,ts,tsx,md,mdx}": [
            "eslint --fix"
        ],
        "./cdk/**/*.{js,ts}": [
            "eslint --fix"
        ]
    },
    "dependencies": {
        "@emotion/react": "^11.10.4",
        "@emotion/styled": "^11.10.4",
        "@fontsource/nunito": "^4.5.10",
