        "@reach/accordion": "^0.16.1",
        "@reach/dialog": "^0.16.2",
        "@reach/menu-button": "^0.16.2",
        "@reach/skip-nav": "^0.16.0",
        "@svgr/webpack": "^6.3.1",
        "emotion-normalize": "^11.0.1",
        "focus-trap-react": "^10.0.0",
        "gatsby": "^4.23.1",
        "gatsby-plugin-canonical-urls": "^4.23.0",
